# Social Media Downloader API - Environment Variables
# Copy this file to .env and customize as needed

# ==========================================
# Application Settings
# ==========================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Directory for temporary downloads (inside container)
DOWNLOAD_DIR=/tmp/downloads

# Maximum file size in MB (videos larger than this will be rejected)
MAX_FILE_SIZE=500

# How long to keep downloaded files (in hours)
FILE_RETENTION_HOURS=1

# Interval between cleanup runs (in seconds)
CLEANUP_INTERVAL=3600

# ==========================================
# Performance Settings
# ==========================================

# Number of Uvicorn workers (1-4 recommended)
WORKERS=2

# ==========================================
# Rate Limiting (configured in api.py)
# ==========================================

# Maximum requests per client IP per time window
# RATE_LIMIT_REQUESTS=10

# Time window in seconds
# RATE_LIMIT_WINDOW=60

# ==========================================
# Docker Resource Limits (configured in docker-compose.yml)
# ==========================================

# Maximum CPU cores
# DOCKER_CPU_LIMIT=2.0

# Maximum memory
# DOCKER_MEMORY_LIMIT=2G

# ==========================================
# Notes
# ==========================================

# - Increase WORKERS for better concurrency, but watch memory usage
# - Reduce MAX_FILE_SIZE if disk space is limited
# - Adjust FILE_RETENTION_HOURS based on your use case
# - Lower LOG_LEVEL to DEBUG for troubleshooting
