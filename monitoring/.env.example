# Example environment for monitoring stack
# Set the external app metrics target reachable from containers (host:port)
APP_METRICS_TARGET_HOST=host.docker.internal:44300
APP_METRICS_TARGET_PATH=/api/v1/metrics
# Optional scheme (http or https)
APP_METRICS_SCHEME=http
# Images (pin to specific versions for reproducibility)
PROMETHEUS_IMAGE=prom/prometheus:v2.49.0
GRAFANA_IMAGE=grafana/grafana:10.1.3
# Grafana admin password (override in production)
GF_SECURITY_ADMIN_PASSWORD=admin
